{
  "name": "immich-webos",
  "version": "0.9.7",
  "description": "Native webOS TV app for browsing an Immich photo/video server",
  "private": true,
  "license": "MIT",
  "author": "Aneesh Tigga",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:vite": "vite",
    "relay": "node relay/server.mjs",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host",
    "package": "npm run build && ares-package dist service -o out",
    "install-tv": "ares-install --device lg_c2 ./out/com.immich.webos_$(node -p \"require('./package.json').version\")_all.ipk",
    "launch": "ares-launch --device lg_c2 com.immich.webos",
    "deploy": "node scripts/deploy.mjs",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@mdi/js": "^7.4.47",
    "preact": "^10.22.0",
    "qrcode-generator": "^1.5.2"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.9.0",
    "@webos-tools/cli": "^3.1.0",
    "patch-package": "^8.0.1",
    "sharp": "^0.35.2",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  }
}
